# Copy to .env and fill in wallet / paths. See scripts/miner/run/run_miner.sh

# --- Dynamic threshold (miner: neurons/miner.py) ---
# 0 = OFF — fixed bot/human cutoff (production_threshold.json in bundle, else 0.5)
# 1 = ON  — gap-based threshold per validator request when scores are bimodal
POKER44_DYNAMIC_THRESHOLD=0
POKER44_THRESHOLD_FALLBACK=0.5
POKER44_THRESHOLD_CLAMP_MIN=0.10
POKER44_THRESHOLD_CLAMP_MAX=0.45
POKER44_THRESHOLD_MIN_SCORES=20
POKER44_THRESHOLD_ROLLING_WINDOW=500
# POKER44_PRODUCTION_THRESHOLD_JSON=/path/to/production_threshold.json

# Production v12 bundle (canonical: workspace/model/artifacts/)
# POKER44_MINER_MODEL_BUNDLE_DIR=workspace/model/artifacts/model_bundle_v12_prod
# POKER44_MINER_MODEL_PATH=workspace/model/artifacts/model_bundle_v12_prod/model.joblib
# POKER44_MINER_TRANSFORM_META_PATH=workspace/model/artifacts/model_bundle_v12_prod/transform_meta.json
# POKER44_PRODUCTION_THRESHOLD_JSON=workspace/model/artifacts/model_bundle_v12_prod/production_threshold.json
# POKER44_THRESHOLD_FALLBACK=0.64
# POKER44_DYNAMIC_THRESHOLD=0
