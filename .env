# Model + on-the-wire parity: features = aggregate_chunk_from_hands(chunk) in poker44.validator.chunk_features
# (same path as preprocess_lightgbm). Optional: POKER44_MINER_TRANSFORM_META_PATH=.../transform_meta.json next to joblib.
# POKER44_FEATURE_PIPELINE_FORCE_RESANITIZE=1  # debug: always re-run sanitize_hand_for_miner on every hand
POKER44_MINER_MODEL_PATH=/root/Workspace/miner_1/workspace/model/artifacts/lgbm_miner_2/lgbm_classifier.joblib

POKER44_MINER_LOG_REQUESTS=1
POKER44_MINER_LOG_FULL_CHUNKS=1
# One JSON line per chunk: chunk_hash, chunk, risk_score (raw when lengths match).
# Overrides batched ssl/slim row shape for successful chunk logs only.
POKER44_MINER_LOG_CHUNK_NDJSON=1
POKER44_MINER_LOG_ASYNC=1

# When 1, chunk payloads (incl. CHUNK_NDJSON) only if log_state=normal; high/extreme falls back to other log rows.
POKER44_MINER_ADAPTIVE_LOGGING=1
# Ignored for body when CHUNK_NDJSON=1 and chunks are logged; still used if adaptive skips chunk logging.
POKER44_MINER_LOG_SLIM_EXPORT=0
POKER44_MINER_VALIDATOR_TIMEOUT_MS=20000
POKER44_MINER_LOG_PATH=/root/Workspace/miner_1/workspace/real_distribution/miner_requests.jsonl

POKER44_MINER_UNCERTAIN_A=0.3
POKER44_MINER_UNCERTAIN_B=0.7
POKER44_MINER_UNCERTAIN_GAMMA=1.4

POKER44_MINER_DEBUG_FIRST_INFERENCE=1
POKER44_MINER_REQUIRE_MODEL=1

POKER44_MINER_LOG_DAILY_ROTATE=1h

